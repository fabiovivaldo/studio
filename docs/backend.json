
{
  "entities": {
    "PonteiroData": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PonteiroData",
      "type": "object",
      "description": "Represents a single row of extracted data from the 'Ponteiros.html' URL, containing various pointer-related information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (Funcao_DataTurno)."
        },
        "funcao": {
          "type": "string",
          "description": "The function or operation associated with the pointer."
        },
        "sinal": {
          "type": "string",
          "description": "The signal or status associated with the pointer."
        },
        "original1": {
          "type": "string",
          "description": "The first original pointer value."
        },
        "temporario1": {
          "type": "string",
          "description": "The first temporary pointer value."
        },
        "original2": {
          "type": "string",
          "description": "The second original pointer value."
        },
        "temporario2": {
          "type": "string",
          "description": "The second temporary pointer value."
        },
        "dataTurno": {
          "type": "string",
          "description": "The date and shift of the record."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this record was archived."
        }
      },
      "required": [
        "id",
        "funcao",
        "sinal",
        "original1",
        "temporario1",
        "original2",
        "temporario2",
        "dataTurno"
      ]
    },
    "FainaPreference": {
      "title": "FainaPreference",
      "type": "object",
      "description": "User defined faina preferences with custom call names and groupings.",
      "properties": {
        "id": {
          "type": "string"
        },
        "faina": {
          "type": "string",
          "description": "The name of the faina."
        },
        "chamada": {
          "type": "string",
          "description": "The custom call name for this faina."
        },
        "teto": {
          "type": "string",
          "description": "O valor máximo do ponteiro antes de reiniciar o ciclo."
        },
        "tipo": {
          "type": "string",
          "enum": ["1", "2"],
          "description": "Determines if the card shows Original/Temp 1 or 2."
        },
        "modo": {
          "type": "string",
          "enum": ["original", "temporario"],
          "description": "Escolha entre monitorar o valor Original ou o Temporário (Ponteiro)."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this preference."
        }
      },
      "required": ["id", "faina", "chamada", "teto", "tipo", "modo", "userId"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/ponteiro_data/{ponteiroDataId}",
        "definition": {
          "entityName": "PonteiroData",
          "schema": {
            "$ref": "#/backend/entities/PonteiroData"
          },
          "description": "Stores the dynamically extracted and archived records.",
          "params": [
            {
              "name": "ponteiroDataId",
              "description": "Unique identifier."
            }
          ]
        }
      },
      {
        "path": "/faina_preferences/{preferenceId}",
        "definition": {
          "entityName": "FainaPreference",
          "schema": {
            "$ref": "#/backend/entities/FainaPreference"
          },
          "description": "User-specific mapping for fainas.",
          "params": [
            {
              "name": "preferenceId",
              "description": "Unique identifier for the preference."
            }
          ]
        }
      }
    ]
  }
}
